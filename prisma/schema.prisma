generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Clients {
    id String @id @default(uuid())

    name     String
    lastname String?

    companyName String?
    position    String?

    city    String
    address String?

    razonSocial String?
    nit         String?

    email1 String
    email2 String?

    phone1 String
    phone2 String?

    notes String?

    isActive Boolean @default(true)

    company   Company? @relation(fields: [companyId], references: [id])
    companyId String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("clients")
}

model Company {
    id          String  @id @default(uuid())
    name        String
    description String?
    direction   String?

    isActive Boolean @default(true)

    clients Clients[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("companies")
}
